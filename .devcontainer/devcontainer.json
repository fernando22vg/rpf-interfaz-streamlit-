{
  "name": "Interfaz Analisis RPF",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.12-bookworm",
  "customizations": {
    "codespaces": {
      "openFiles": [
        "README.md",
        "Interfaz_RPF/interfaz_analisis_RPF.py"
      ]
    },
    "vscode": {
      "settings": {},
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance"
      ]
    }
  },
  "updateContentCommand": "[ -f Interfaz_RPF/requirements.txt ] && pip3 install --user -r Interfaz_RPF/requirements.txt; echo '✅ Dependencias instaladas'",
  "postAttachCommand": {
    "server": "streamlit run Interfaz_RPF/interfaz_analisis_RPF.py --server.enableCORS false --server.enableXsrfProtection false"
  },
  "portsAttributes": {
    "8501": {
      "label": "Interfaz RPF",
      "onAutoForward": "openPreview"
    }
  },
  "forwardPorts": [
    8501
  ]
}
