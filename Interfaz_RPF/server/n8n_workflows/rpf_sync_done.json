{
  "name": "RPF - Sync Done Monitor",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "rpf-sync-done",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "aed4ee3d-afd9-407f-aea2-ac22d4ed8b69",
      "name": "Webhook Sync Done",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [-880, 112],
      "webhookId": "rpf-sync-done"
    },
    {
      "parameters": {
        "jsCode": "// Extraer y transformar el payload del daemon\nconst body = $input.first().json.body || $input.first().json;\n\nconst totalMB = (body.total_bytes / 1048576).toFixed(2);\nconst haErrors = body.total_errors > 0;\nconst statsJson = JSON.stringify(body.stats || {});\n\n// Parsear timestamp del daemon (ISO format)\nconst ts = body.timestamp ? new Date(body.timestamp).toISOString() : new Date().toISOString();\n\n// Construir resumen legible\nconst folders = Object.keys(body.stats || {});\nconst folderSummary = folders.map(f => {\n  const s = body.stats[f];\n  return `${f}: ${s.downloaded} archivos, ${(s.bytes_downloaded/1048576).toFixed(1)} MB`;\n}).join(' | ');\n\nreturn [{\n  json: {\n    sync_started_at: ts,\n    total_downloaded: body.total_downloaded || 0,\n    total_errors: body.total_errors || 0,\n    total_mb: parseFloat(totalMB),\n    stats_json: statsJson,\n    folder_summary: folderSummary,\n    dry_run: body.dry_run || false,\n    has_errors: haErrors,\n    status: haErrors ? 'sync_with_errors' : 'sync_ok',\n    message: `Sync OK: ${body.total_downloaded} archivos, ${totalMB} MB`\n  }\n}];"
      },
      "id": "714cd392-e6eb-4c67-9aed-7bddd1efebd4",
      "name": "Transformar Datos",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-656, 112]
    },
    {
      "parameters": {
        "schema": {
          "__rl": true,
          "value": "public",
          "mode": "list",
          "cachedResultName": "public"
        },
        "table": {
          "__rl": true,
          "value": "rpf_sync_log",
          "mode": "list",
          "cachedResultName": "rpf_sync_log"
        },
        "columns": {
          "mappingMode": "defineBelow",
          "value": {
            "files_downloaded": "={{ $json.total_downloaded }}",
            "files_skipped":    0,
            "errors":           "={{ $json.total_errors }}",
            "bytes_downloaded": "={{ Math.round($json.total_mb * 1048576) }}",
            "dry_run":          "={{ $json.dry_run }}",
            "stats_json":       "={{ $json.stats_json }}"
          },
          "matchingColumns": ["id"],
          "schema": [
            { "id": "id",               "displayName": "id",               "required": false, "defaultMatch": true,  "display": true, "type": "number",   "canBeUsedToMatch": true, "removed": true },
            { "id": "sync_at",          "displayName": "sync_at",          "required": false, "defaultMatch": false, "display": true, "type": "dateTime", "canBeUsedToMatch": true },
            { "id": "duration_secs",    "displayName": "duration_secs",    "required": false, "defaultMatch": false, "display": true, "type": "number",   "canBeUsedToMatch": true },
            { "id": "files_downloaded", "displayName": "files_downloaded", "required": false, "defaultMatch": false, "display": true, "type": "number",   "canBeUsedToMatch": true },
            { "id": "files_skipped",    "displayName": "files_skipped",    "required": false, "defaultMatch": false, "display": true, "type": "number",   "canBeUsedToMatch": true },
            { "id": "errors",           "displayName": "errors",           "required": false, "defaultMatch": false, "display": true, "type": "number",   "canBeUsedToMatch": true },
            { "id": "bytes_downloaded", "displayName": "bytes_downloaded", "required": false, "defaultMatch": false, "display": true, "type": "number",   "canBeUsedToMatch": true },
            { "id": "dry_run",          "displayName": "dry_run",          "required": false, "defaultMatch": false, "display": true, "type": "boolean",  "canBeUsedToMatch": true },
            { "id": "stats_json",       "displayName": "stats_json",       "required": false, "defaultMatch": false, "display": true, "type": "object",   "canBeUsedToMatch": true }
          ],
          "attemptToConvertTypes": false,
          "convertFieldsToString": false
        },
        "options": {}
      },
      "id": "a21e439b-d687-4fcf-b694-f96cd3e5ff8d",
      "name": "PostgreSQL: Log Sync",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [-448, 112],
      "credentials": {
        "postgres": {
          "id": "kgt3UvzOqcKrNzhH",
          "name": "Postgres account"
        }
      }
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict",
            "version": 1
          },
          "conditions": [
            {
              "id": "check-errors",
              "leftValue": "={{ $('Transformar Datos').first().json.total_errors }}",
              "rightValue": 0,
              "operator": { "type": "number", "operation": "gt" }
