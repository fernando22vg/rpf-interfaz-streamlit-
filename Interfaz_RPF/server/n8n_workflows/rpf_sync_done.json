      "id": "06daf138-ffa3-486a-aa4e-b7a5a5193f46",
      "name": "¿Tiene errores?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [-224, 112]
    },
    {
      "parameters": {
        "jsCode": "// Log de alerta - en el futuro puede enviar email/Telegram\nconst data = $('Transformar Datos').first().json;\nconsole.log(`[RPF ALERTA] Sync con ${data.total_errors} errores`);\nconsole.log(`Stats: ${data.folder_summary}`);\n\nreturn [{ json: { alerta: 'sync_con_errores', ...data } }];"
      },
      "id": "55d2c843-efbc-4a2b-bbcd-afad95587365",
      "name": "Log Alerta",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [0, 0]
    },
    {
      "parameters": {
        "jsCode": "// Sync exitoso - log informativo\nconst data = $('Transformar Datos').first().json;\nconsole.log(`[RPF OK] ${data.message}`);\nconsole.log(`Detalle: ${data.folder_summary}`);\n\nreturn [{ json: { status: 'ok', ...data } }];"
      },
      "id": "956c2f6c-a9b5-495d-9bf7-1a7a18c87cc7",
      "name": "Log OK",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [0, 224]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ JSON.stringify({ ok: true, received: $('Transformar Datos').first().json.message }) }}",
        "options": { "responseCode": 200 }
      },
      "id": "d0be32a1-f1fe-4fbe-b72e-32c6f2a34a50",
      "name": "Responder 200",
